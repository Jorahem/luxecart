<%= form_with url: search_path, method: :get, local: true, class: "w-full max-w-md" do |f| %>
  <div class="flex items-center bg-white/5 dark:bg-slate-900 rounded-full px-3 py-1">
    <%= f.search_field :q,
          value: params[:q],
          placeholder: "Search for products...",
          class: "flex-1 bg-transparent border-0 focus:ring-0 text-sm text-white placeholder:text-slate-400" %>
    <button type="submit" class="ml-2 text-slate-300 hover:text-emerald-300">
      🔍
    </button>
  </div>
<% end %>