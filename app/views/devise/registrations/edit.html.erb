<div class="min-h-screen bg-gradient-to-br from-purple-50 via-white to-blue-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <!-- Page heading -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        <span class="text-purple-600">LUXE</span>CART
      </h1>
      <h2 class="text-2xl font-semibold text-gray-800 mb-2">
        Account settings
      </h2>
      <p class="text-gray-600 text-sm">
        Update your email or password. For security reasons we need your current password to confirm changes.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-[minmax(0,2fr),minmax(0,1fr)] items-start">
      <!-- Edit account form card -->
      <div class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-8">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">
          Profile & security
        </h3>

        <%= form_for(resource,
                     as: resource_name,
                     url: registration_path(resource_name),
                     html: { method: :put, class: "space-y-6" }) do |f| %>

          <%= render "devise/shared/error_messages", resource: resource %>

          <!-- Email -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Email address
            </label>
            <%= f.email_field :email,
                  autofocus: true,
                  autocomplete: "email",
                  class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm px-3 py-2" %>
            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <p class="mt-1 text-xs text-amber-600">
                Currently waiting confirmation for:
                <span class="font-medium"><%= resource.unconfirmed_email %></span>
              </p>
            <% end %>
          </div>

          <!-- New password -->
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="block text-sm font-medium text-gray-700">
                New password
              </label>
              <p class="text-xs text-gray-400">
                Leave blank if you don’t want to change it
              </p>
            </div>
            <div class="relative">
              <%= f.password_field :password,
                    id: "user_password",
                    autocomplete: "new-password",
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm px-3 py-2 pr-10" %>
              <!-- eye button -->
              <button type="button"
                      data-toggle-password="user_password"
                      class="absolute inset-y-0 right-0 px-3 flex items-center text-gray-400 hover:text-gray-600 text-sm">
                <span data-eye-icon="show">👁</span>
                <span data-eye-icon="hide" class="hidden">🙈</span>
              </button>
            </div>
            <% if @minimum_password_length %>
              <p class="mt-1 text-xs text-gray-400">
                <%= @minimum_password_length %> characters minimum
              </p>
            <% end %>
          </div>

          <!-- Confirm new password -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Confirm new password
            </label>
            <div class="relative">
              <%= f.password_field :password_confirmation,
                    id: "user_password_confirmation",
                    autocomplete: "new-password",
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm px-3 py-2 pr-10" %>
              <button type="button"
                      data-toggle-password="user_password_confirmation"
                      class="absolute inset-y-0 right-0 px-3 flex items-center text-gray-400 hover:text-gray-600 text-sm">
                <span data-eye-icon="show">👁</span>
                <span data-eye-icon="hide" class="hidden">🙈</span>
              </button>
            </div>
          </div>

          <!-- Current password -->
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="block text-sm font-medium text-gray-700">
                Current password
              </label>
              <p class="text-xs text-gray-400">
                Required to confirm changes
              </p>
            </div>
            <div class="relative">
              <%= f.password_field :current_password,
                    id: "user_current_password",
                    autocomplete: "current-password",
                    class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm px-3 py-2 pr-10" %>
              <button type="button"
                      data-toggle-password="user_current_password"
                      class="absolute inset-y-0 right-0 px-3 flex items-center text-gray-400 hover:text-gray-600 text-sm">
                <span data-eye-icon="show">👁</span>
                <span data-eye-icon="hide" class="hidden">🙈</span>
              </button>
            </div>
          </div>

          <!-- Submit -->
          <div class="pt-2">
            <%= f.submit "Save changes",
                  class: "inline-flex justify-center items-center px-5 py-2.5 border border-transparent text-sm font-semibold rounded-lg shadow-sm text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 w-full sm:w-auto" %>
          </div>
        <% end %>

        <div class="mt-6">
          <%= link_to "Back to profile",
                profile_path,
                class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" rescue nil %>
        </div>
      </div>

      <!-- Danger zone: cancel account -->
      <div class="space-y-4">
        <div class="bg-white rounded-2xl border border-red-100 p-6">
          <h3 class="text-sm font-semibold text-red-600 mb-1">
            Danger zone
          </h3>
          <p class="text-xs text-gray-600 mb-4">
            Deleting your account will remove your profile and order history. This action cannot be undone.
          </p>

          <%= button_to "Cancel my account",
                registration_path(resource_name),
                method: :delete,
                data: { confirm: "Are you sure you want to permanently delete your LuxeCart account?" },
                class: "inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-semibold rounded-lg text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 w-full" %>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-5 text-sm text-gray-600">
          <p class="font-medium text-gray-900 mb-1">
            Tip
          </p>
          <p>
            If you only want to stop receiving marketing emails, you can
            update your email preferences from any newsletter instead of deleting your account.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Simple show/hide password script -->
<script>
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll("[data-toggle-password]").forEach(function(button) {
      button.addEventListener("click", function() {
        const inputId = this.getAttribute("data-toggle-password");
        const input = document.getElementById(inputId);
        if (!input) return;

        const showIcon = this.querySelector("[data-eye-icon='show']");
        const hideIcon = this.querySelector("[data-eye-icon='hide']");

        if (input.type === "password") {
          input.type = "text";
          if (showIcon) showIcon.classList.add("hidden");
          if (hideIcon) hideIcon.classList.remove("hidden");
        } else {
          input.type = "password";
          if (showIcon) showIcon.classList.remove("hidden");
          if (hideIcon) hideIcon.classList.add("hidden");
        }
      });
    });
  });
</script>